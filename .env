# ── 한국투자증권 KIS API ──────────────────────────────────────
# https://apiportal.koreainvestment.com 에서 앱 등록 후 발급
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=00000000-01        # 계좌번호-상품코드

# 모드: paper (모의투자) | real (실투자)
TRADING_MODE=paper

# ── Anthropic Claude API ─────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── 에이전트 설정 ─────────────────────────────────────────────
AGENT_INTERVAL_SEC=60             # 에이전트 판단 주기 (초)
TIER2_CONFIDENCE_THRESHOLD=60    # Tier2 호출 기준 신뢰도
ORDER_AMOUNT=500000               # 1회 매수 금액 (원)
MAX_POSITION_PCT=20               # 종목당 최대 비중 (%)
DAILY_LOSS_LIMIT_PCT=3           # 일일 최대 손실 한도 (%)
